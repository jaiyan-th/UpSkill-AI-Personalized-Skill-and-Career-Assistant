# ========================================
# UpSkill AI - Environment Configuration
# ========================================

# Required: Groq API Key (FREE - get from https://console.groq.com/)
# Sign up at Groq and create an API key
GROQ_API_KEY=your_groq_api_key_here

# Required: JWT Secret (generate a random string)
# Use: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_super_secret_key_here

# Database Configuration
DATABASE_PATH=skilliq.db

# LLM Model Selection
# Options: llama-3.1-70b-versatile, mixtral-8x7b-32768, llama-3.1-8b-instant
GROQ_MODEL=llama-3.1-70b-versatile

# Optional: OpenAI API Key (if you want to use GPT models)
# OPENAI_API_KEY=your_openai_key_here

# Optional: Anthropic API Key (if you want to use Claude)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Server Configuration
# PORT=5000
# HOST=0.0.0.0

# ========================================
# Email Configuration (SMTP)
# ========================================
# Enable/disable email notifications
EMAIL_ENABLED=true

# SMTP Server Configuration
# For Gmail: smtp.gmail.com
# For Outlook: smtp-mail.outlook.com
# For SendGrid: smtp.sendgrid.net
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Email Credentials
# For Gmail: Use App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Email Display Name
EMAIL_FROM_NAME=UpSkill AI

# ========================================
# Gmail Setup Instructions:
# ========================================
# 1. Enable 2-Factor Authentication on your Google Account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Select "Mail" and "Other (Custom name)"
# 4. Name it "UpSkill AI" and click Generate
# 5. Copy the 16-character password (no spaces)
# 6. Paste it as EMAIL_PASS above
# ========================================
